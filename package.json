{
    "$schema": "https://json.schemastore.org/package",
    "name": "@kayahr/xbrz",
    "version": "1.1.1",
    "type": "module",
    "description": "A high-quality image upscaling filter for creating beautiful HD representations from low-resolution images",
    "keywords": [
        "xbrz",
        "scaling",
        "upscaling",
        "image-scaling",
        "pixel-art",
        "pixel-scaling",
        "image-processing",
        "typescript",
        "assemblyscript",
        "wasm"
    ],
    "license": "GPL-3.0-only",
    "author": "Klaus Reimer <k@ailis.de>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kayahr/xbrz.git"
    },
    "homepage": "https://github.com/kayahr/xbrz",
    "bugs": "https://github.com/kayahr/xbrz/issues",
    "funding": "https://github.com/kayahr/xbrz?sponsor=1",
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "lib/main/",
        "src/main/"
    ],
    "exports": "./lib/main/index.js",
    "scripts": {
        "clean": "rm -rf lib",
        "build": "run build:*",
        "build:compile": "tsc",
        "build:wasm": "asc",
        "build:serialize-wasm": "scripts/serialize-wasm.js",
        "test": "run test:*",
        "test:unit": "ntest",
        "test:spell": "cspell --no-progress --no-summary",
        "test:lint": "oxlint --type-aware --deny-warnings",
        "test:apidoc": "typedoc --emit none",
        "apidoc": "typedoc",
        "prepare": "run clean build"
    },
    "devDependencies": {
        "@kayahr/assert": "1.4.0",
        "@kayahr/cspell": "9.7.0-bundle.1",
        "@kayahr/npm-utils": "1.1.1",
        "@kayahr/ntest": "1.3.0",
        "@kayahr/oxlint-config": "1.30.0",
        "@kayahr/typedoc": "0.28.17-bundle.1",
        "@types/node": "25.5.0",
        "@types/pngjs": "6.0.5",
        "assemblyscript": "^0.28.10",
        "pixelmatch": "7.1.0",
        "pngjs": "7.0.0",
        "typescript": "5.9.3"
    }
}
